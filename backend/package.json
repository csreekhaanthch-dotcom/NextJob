{
  "name": "nextjob-backend",
  "version": "2.0.0",
  "description": "NextJob backend API server with ATS scrapers for 100+ companies",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:init": "node scripts/init-db.js",
    "db:migrate": "node scripts/init-db.js",
    "scrape": "RUN_NOW=true node scripts/scheduler.js",
    "scheduler": "node scripts/scheduler.js",
    "setup": "node scripts/setup.js",
    "postinstall": "node scripts/init-db.js",
    "clean": "rm -rf node_modules"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "better-sqlite3": "^12.1.0",
    "cheerio": "^1.0.0-rc.12",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "joi": "^17.13.3",
    "node-cron": "^3.0.3",
    "node-fetch": "^2.7.0",
    "p-limit": "^4.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.13",
    "supertest": "^7.0.0",
    "vitest": "^2.0.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "preferGlobal": false
}
