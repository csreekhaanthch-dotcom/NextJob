# Adzuna API Credentials (required for job searches)
# Get these from https://developer.adzuna.com/
ADZUNA_APP_ID=your_adzuna_app_id_here
ADZUNA_API_KEY=your_adzuna_api_key_here

# JWT Secret for authentication (you can change this to any secret phrase)
JWT_SECRET=nextjob_secret_key_change_this_in_production

# Leave these empty to use fallback options (no MongoDB/Redis required for basic functionality)
# MONGODB_URI=
# REDIS_URL=

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# Port for backend server
PORT=3001