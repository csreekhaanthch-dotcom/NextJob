# Adzuna API Credentials (optional)
# Get these from https://developer.adzuna.com/
ADZUNA_APP_ID=your_adzuna_app_id_here
ADZUNA_API_KEY=your_adzuna_api_key_here

# USAJOBS API Key (optional)
# Get from https://developer.usajobs.gov/
USAJOBS_API_KEY=your_usajobs_api_key_here

# JSearch API Key (optional)
# Get from RapidAPI: https://rapidapi.com/jearch-api/api-jsearch/
JSEARCH_API_KEY=your_jsearch_api_key_here

# ATS Scrapers Configuration
# Enable/disable ATS scrapers (greenhouse, lever)
ENABLE_GREENHOUSE_SCRAPER=true
ENABLE_LEVER_SCRAPER=true

# Scraper Priority Level (1=highest priority companies, 5=all companies)
# Lower numbers = top-tier companies, Higher numbers = more companies
SCRAPER_PRIORITY=2

# Scraper Cache TTL in milliseconds (default: 3600000 = 1 hour)
SCRAPER_CACHE_TTL=3600000

# Log Level (error, warn, info, debug)
LOG_LEVEL=info

# Port for backend server
PORT=3001