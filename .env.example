# Adzuna API Credentials (required for job searches)
ADZUNA_APP_ID=your_adzuna_app_id_here
ADZUNA_API_KEY=your_adzuna_api_key_here

# JWT Secret for authentication
JWT_SECRET=your_jwt_secret_here

# MongoDB Connection URI (optional but recommended for production)
MONGODB_URI=mongodb://localhost:27017/nextjob

# Redis Connection URI (optional but recommended for production)
REDIS_URL=redis://localhost:6379

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# Port for backend server
PORT=3001