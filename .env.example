# NextJob Environment Configuration
# Copy this file to .env and update the values

# ==========================================
# Database Configuration
# ==========================================
# Path to SQLite database (optional - defaults to ./data/jobs.db)
# DB_PATH=./data/jobs.db

# ==========================================
# Job Board API Credentials (Optional)
# ==========================================
# Adzuna API - https://developer.adzuna.com/
ADZUNA_APP_ID=your_adzuna_app_id_here
ADZUNA_API_KEY=your_adzuna_api_key_here

# USAJOBS API - https://developer.usajobs.gov/
USAJOBS_API_KEY=your_usajobs_api_key_here

# JSearch API (RapidAPI) - https://rapidapi.com/jearch-api/api-jsearch/
JSEARCH_API_KEY=your_jsearch_api_key_here

# ==========================================
# ATS Scrapers Configuration
# ==========================================
# Enable/disable specific scrapers
ENABLE_GREENHOUSE_SCRAPER=true
ENABLE_LEVER_SCRAPER=true

# Scraper Priority Level (1=highest priority companies, 5=all companies)
# 1 = Top companies only (Stripe, Airbnb, etc.)
# 2 = Priority 1 + major SaaS companies
# 3 = Priority 1-2 + more companies
# 4-5 = All 100+ companies
SCRAPER_PRIORITY=2

# ==========================================
# Scheduler Configuration
# ==========================================
# Enable/disable background job scheduler
ENABLE_SCHEDULER=true

# Cron schedule for automatic scraping (default: every 6 hours)
# Format: minute hour day month day-of-week
# Examples: 
#   '0 */6 * * *' = Every 6 hours
#   '0 0 * * *' = Daily at midnight
#   '*/30 * * * *' = Every 30 minutes
SCRAPER_SCHEDULE=0 */6 * * *

# ==========================================
# Cache Configuration
# ==========================================
# Cache TTL in milliseconds (default: 24 hours = 86400000)
SCRAPER_CACHE_TTL=86400000

# Maximum jobs to cache per source
MAX_JOBS_PER_SOURCE=1000

# ==========================================
# Server Configuration
# ==========================================
# Port for backend server (default: 3001)
PORT=3001

# Admin secret for admin endpoints (generate a strong random string)
ADMIN_SECRET=your_admin_secret_here_change_in_production

# ==========================================
# Logging Configuration
# ==========================================
# Log level: error, warn, info, debug
LOG_LEVEL=info

# ==========================================
# Frontend Configuration (for reference)
# ==========================================
# API URL for frontend
# NEXT_PUBLIC_API_URL=http://localhost:3001